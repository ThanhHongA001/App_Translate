<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_evaluation"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="@dimen/screen_padding"
    tools:context=".ui.evaluation.EvaluationActivity">

    <TextView
        android:id="@+id/evaluation_TvTile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/evaluation_title"
        android:gravity="center"
        style="@style/TextTitle"
        android:layout_marginBottom="18dp" />

    <EditText
        android:id="@+id/evaluation_EditComment"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:gravity="top|start"
        android:hint="@string/evaluation_hint"
        android:inputType="textMultiLine"
        android:padding="14dp"
        android:background="@drawable/bg_edittext"
        style="@style/TextBody"
        android:layout_marginBottom="14dp" />

    <Button
        android:id="@+id/evaluation_BtnSubmit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/submit"
        style="@style/ButtonPrimary"
        android:layout_marginBottom="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/evaluation_RcvResult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_evaluation_result" />

</LinearLayout>