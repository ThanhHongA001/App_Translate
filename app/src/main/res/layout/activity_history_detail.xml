<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_history_detail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.history.HistoryDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <ImageButton
                android:id="@+id/history_detail_BtnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:contentDescription="@string/button_back" />

            <TextView
                android:id="@+id/history_detail_TvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/history_detail"
                android:gravity="center"
                style="@style/TextSubtitle" />

            <ImageButton
                android:id="@+id/history_detail_BtnDelete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:contentDescription="@string/button_delete" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/input_text"
            style="@style/TextSmall"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/history_detail_TvSourceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:padding="14dp"
            android:background="@drawable/bg_card"
            style="@style/TextBody"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result_text"
            style="@style/TextSmall"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/history_detail_TvTranslatedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:padding="14dp"
            android:background="@drawable/bg_result"
            style="@style/TextBody"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/history_detail_TvCreatedAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/TextSmall" />

    </LinearLayout>

</ScrollView>