<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.translate.TranslateActivity">

    <LinearLayout
        android:id="@+id/activity_translate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/translate_BtnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/menu"
                android:padding="10dp"
                android:src="@drawable/ic_menu" />

            <TextView
                android:id="@+id/translate_TvTitle"
                style="@style/TextTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/translate" />

            <ImageButton
                android:id="@+id/translate_BtnHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/history"
                android:padding="10dp"
                android:src="@drawable/ic_history" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/translate_LanguageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/translate_TvSourceLanguage"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spinner"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <ImageButton
                android:id="@+id/translate_BtnSwapLanguage"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/swap_language"
                android:padding="12dp"
                android:src="@drawable/ic_swap" />

            <Spinner
                android:id="@+id/translate_TvTargetLanguage"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spinner"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

        <EditText
            android:id="@+id/translate_EdtInputText"
            style="@style/TextBody"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_edittext"
            android:gravity="top|start"
            android:hint="@string/input_text_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="6"
            android:overScrollMode="always"
            android:padding="14dp"
            android:scrollbars="vertical"
            android:textCursorDrawable="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/translate_BtnTranslate"
                style="@style/ButtonPrimary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/button_translate" />

            <Button
                android:id="@+id/translate_BtnClear"
                android:layout_width="100dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_card"
                android:text="@string/button_clear"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/translate_ProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/translate_TvResultLabel"
            style="@style/TextSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/result_text" />

        <TextView
            android:id="@+id/translate_TvTranslatedText"
            style="@style/TextBody"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_result"
            android:gravity="top|start"
            android:padding="14dp"
            android:text="@string/result_text_hint" />

        <Button
            android:id="@+id/translate_BtnCopy"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_card"
            android:text="@string/button_copy"
            android:textColor="@color/primary"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>