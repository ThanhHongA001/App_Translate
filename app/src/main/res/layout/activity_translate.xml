<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.translate.TranslateActivity">

    <LinearLayout
        android:id="@+id/activity_translate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/translate_BtnHistory"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_menu"
                android:background="@drawable/bg_card" />

            <TextView
                android:id="@+id/translate_TvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/translate"
                android:gravity="center"
                style="@style/TextTitle"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/translate_LanguageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/translate_TvSourceLanguage"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/vietnamese"
                android:background="@drawable/bg_spinner"
                style="@style/TextBody" />

            <ImageButton
                android:id="@+id/translate_BtnSwapLanguage"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_card"
                android:src="@drawable/ic_swap"
                android:contentDescription="@string/swap_language"
                android:padding="12dp" />

            <TextView
                android:id="@+id/translate_TvTargetLanguage"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/english"
                android:background="@drawable/bg_spinner"
                style="@style/TextBody" />

        </LinearLayout>

        <EditText
            android:id="@+id/translate_EdtInputText"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="top|start"
            android:hint="@string/input_text_hint"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:padding="14dp"
            android:background="@drawable/bg_edittext"
            style="@style/TextBody"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/translate_BtnTranslate"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="@string/button_translate"
                style="@style/ButtonPrimary" />

            <Button
                android:id="@+id/translate_BtnClear"
                android:layout_width="100dp"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:text="@string/button_clear"
                android:textColor="@color/primary"
                android:background="@drawable/bg_card"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/translate_TvResultLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result_text"
            style="@style/TextSubtitle"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/translate_TvTranslatedText"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="top|start"
            android:text="@string/result_text_hint"
            android:padding="14dp"
            android:background="@drawable/bg_result"
            style="@style/TextBody"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/translate_BtnCopy"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="@string/button_copy"
            android:textColor="@color/primary"
            android:background="@drawable/bg_card"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>